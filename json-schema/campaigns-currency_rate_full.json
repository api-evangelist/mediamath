{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "currency_rate_full",
  "allOf": [
    {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "version": {
          "type": "integer"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "currency_code": {
          "type": "string",
          "maxLength": 3
        },
        "rate": {
          "type": "number",
          "format": "float"
        },
        "created_on": {
          "type": "string",
          "format": "date-time",
          "readOnly": true
        },
        "updated_on": {
          "type": "string",
          "format": "date-time",
          "readOnly": true
        }
      }
    }
  ]
}