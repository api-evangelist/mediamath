{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "error response",
  "type": "object",
  "required": [
    "errors",
    "meta"
  ],
  "properties": {
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "field": {
            "description": "Optional when it is a schema error",
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string"
        }
      }
    }
  }
}