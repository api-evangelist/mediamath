{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "user_create",
  "allOf": [
    {
      "$ref": "#/components/schemas/user_base"
    },
    {
      "type": "object",
      "required": [
        "first_name",
        "last_name",
        "username",
        "roles"
      ],
      "properties": {
        "first_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        },
        "last_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        },
        "phone": {
          "type": "string",
          "maxLength": 24
        },
        "username": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "roles": {
          "$ref": "#/components/schemas/roles"
        }
      }
    }
  ]
}