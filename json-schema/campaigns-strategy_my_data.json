{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "",
  "type": "object",
  "properties": {
    "operator": {
      "type": "string",
      "enum": [
        "AND",
        "OR"
      ],
      "default": "OR"
    },
    "pixels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pixel_id": {
            "type": "integer",
            "format": "int32",
            "example": 65
          }
        },
        "required": [
          "pixel_id"
        ]
      }
    }
  },
  "required": [
    "pixels"
  ]
}