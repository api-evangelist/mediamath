{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "campaign_pacing",
  "type": "object",
  "properties": {
    "pacing_alert": {
      "type": "number",
      "format": "float",
      "default": 0,
      "minimum": 0,
      "maximum": 999.99
    },
    "impression_cap_automatic": {
      "type": "boolean",
      "default": false
    },
    "impression_cap_amount": {
      "type": "integer",
      "nullable": true,
      "format": "int32",
      "example": 11
    },
    "impression_cap_type": {
      "type": "string",
      "enum": [
        "even",
        "asap",
        "no-limit"
      ],
      "default": "no-limit"
    },
    "spend_cap_type": {
      "type": "string",
      "default": "no-limit",
      "enum": [
        "even",
        "asap",
        "no-limit"
      ]
    },
    "spend_cap_amount": {
      "type": "number",
      "nullable": true,
      "format": "float",
      "default": 0,
      "minimum": 0,
      "maximum": 9999999.99
    },
    "spend_cap_automatic": {
      "type": "boolean",
      "default": true
    },
    "brain_intraday_pacing": {
      "type": "boolean",
      "default": false
    },
    "spend_pace_ahead": {
      "description": "feature still in development",
      "type": "boolean",
      "default": false
    },
    "impression_pace_ahead": {
      "description": "feature still in development",
      "type": "boolean",
      "default": false
    }
  }
}