{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "strategy_plan_frequency",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "frequency_type": {
      "type": "string",
      "nullable": true,
      "enum": [
        "even",
        "asap",
        "no-limit",
        "t1-optimized"
      ]
    },
    "frequency_interval": {
      "type": "string",
      "enum": [
        "hour",
        "day",
        "week",
        "month",
        "campaign",
        "not-applicable"
      ]
    },
    "frequency_amount": {
      "type": "integer",
      "format": "int32",
      "example": 5
    },
    "frequency_optimization": {
      "type": "boolean"
    }
  }
}