{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "",
  "type": "object",
  "properties": {
    "operator": {
      "type": "string",
      "enum": [
        "AND",
        "OR"
      ],
      "default": "OR"
    },
    "pixels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pixel_id": {
            "type": "integer"
          },
          "pixel_name": {
            "type": "string",
            "description": "available only when extended",
            "readOnly": true
          },
          "pixel_type": {
            "type": "string",
            "enum": [
              "event",
              "data",
              "dynamic"
            ],
            "description": "available only when extended",
            "readOnly": true
          },
          "owner_type": {
            "type": "string",
            "enum": [
              "advertiser",
              "agency"
            ],
            "description": "available only when extended",
            "readOnly": true
          },
          "owner_id": {
            "type": "integer",
            "description": "available only when extended",
            "readOnly": true
          },
          "owner_name": {
            "type": "string",
            "description": "available only when extended",
            "readOnly": true
          }
        },
        "required": [
          "pixel_id"
        ]
      }
    }
  },
  "required": [
    "pixels"
  ]
}