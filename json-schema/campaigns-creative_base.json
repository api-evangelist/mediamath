{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "creative",
  "type": "object",
  "properties": {
    "atomic_creative_id": {
      "type": "integer",
      "minimum": 1
    },
    "tag": {
      "type": "string"
    },
    "tag_type": {
      "type": "string",
      "enum": [
        "IFRAME_SCRIPT_NOSCRIPT",
        "IFRAME_SCRIPT",
        "IFRAME_NOSCRIPT",
        "IFRAME_IMG",
        "SCRIPT_NOSCRIPT",
        "SCRIPT",
        "NOSCRIPT",
        "IFRAME",
        "IMG",
        "VIDEO"
      ]
    },
    "inner_tag": {
      "type": "string"
    }
  }
}