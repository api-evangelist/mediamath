{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "campaign_ad_server",
  "type": "object",
  "properties": {
    "ad_server_id": {
      "type": "integer",
      "format": "int32",
      "example": 19
    },
    "ad_server_username": {
      "type": "string",
      "maxLength": 64
    },
    "ad_server_password": {
      "type": "string",
      "maxLength": 64
    },
    "use_default_ad_server": {
      "type": "boolean",
      "default": true
    },
    "ad_server_fee": {
      "type": "number",
      "format": "float",
      "minimum": 0,
      "maximum": 9999999.99
    }
  }
}