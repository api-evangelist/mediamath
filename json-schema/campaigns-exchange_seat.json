{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "exchange_seat",
  "type": "object",
  "required": [
    "supply_source_id",
    "seat_identifier"
  ],
  "properties": {
    "supply_source_id": {
      "type": "integer",
      "format": "int32",
      "example": 5
    },
    "seat_identifier": {
      "type": "string"
    },
    "bill_media_to_client": {
      "type": "boolean",
      "default": true,
      "nullable": true
    },
    "rmx_exchange_cost_unit": {
      "type": "string",
      "default": "PCT_MEDIA",
      "nullable": true
    },
    "rmx_exchange_cost_cpm": {
      "type": "number",
      "format": "float",
      "minimum": 0,
      "maximum": 9999999.99,
      "nullable": true
    },
    "rmx_exchange_cost_pct": {
      "type": "number",
      "format": "float",
      "minimum": 0,
      "maximum": 100,
      "nullable": true
    },
    "status": {
      "type": "boolean",
      "default": true,
      "nullable": true
    }
  }
}