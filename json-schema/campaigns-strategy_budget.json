{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "strategy_budget",
  "type": "object",
  "properties": {
    "budget": {
      "type": "number",
      "format": "float",
      "description": "Must be a valid float between 1 and 10000000 USD or its equivalent in other currency.",
      "nullable": true
    },
    "currency_code": {
      "type": "string"
    },
    "margin_pct": {
      "type": "number",
      "format": "float",
      "minimum": 0,
      "maximum": 9999999.9999,
      "nullable": true
    }
  }
}