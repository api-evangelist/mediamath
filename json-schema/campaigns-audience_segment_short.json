{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "audience_segment_short",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32",
      "example": 11
    },
    "name": {
      "type": "string",
      "example": "Name3"
    },
    "full_path": {
      "type": "string",
      "example": "Name1 - Name2 - Name3"
    },
    "cpm": {
      "type": "number",
      "format": "double"
    },
    "user_cpm": {
      "type": "number",
      "format": "double",
      "nullable": true
    },
    "uniques": {
      "type": "integer",
      "format": "int32",
      "nullable": true,
      "example": 12345
    },
    "code": {
      "type": "string",
      "nullable": true
    }
  }
}