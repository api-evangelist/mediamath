{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "strategy_concept_full",
  "allOf": [
    {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "version": {
          "type": "integer"
        },
        "strategy_id": {
          "type": "integer"
        },
        "concept_id": {
          "type": "integer"
        },
        "status": {
          "type": "boolean"
        },
        "weighting": {
          "type": "string",
          "enum": [
            "BUDGET",
            "IMPRESSION",
            "NONE"
          ],
          "default": "NONE"
        },
        "percent": {
          "type": "number",
          "format": "float",
          "nullable": true
        },
        "created_on": {
          "type": "string",
          "format": "date-time",
          "readOnly": true
        },
        "updated_on": {
          "type": "string",
          "format": "date-time",
          "readOnly": true
        }
      }
    }
  ]
}