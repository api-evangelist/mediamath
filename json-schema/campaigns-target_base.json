{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "target_base",
  "type": "object",
  "properties": {
    "parent_id": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "factual_id": {
      "type": "string"
    },
    "mediamath_organization_id": {
      "type": "integer",
      "format": "int32",
      "example": 20
    },
    "target_inet": {
      "type": "string",
      "minLength": 1
    },
    "visible": {
      "type": "boolean"
    },
    "visible_overridden": {
      "type": "boolean"
    },
    "bidder_frequency": {
      "type": "integer",
      "format": "int32",
      "example": 5
    },
    "dimension_code": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "name"
  ]
}